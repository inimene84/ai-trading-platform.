# ──────────────────────────────────────────────────────────────────────────────
# AI HEDGE FUND — COMPLETE CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────

# ── AI Brain (LLM Engine) ───────────────────────────────────────────────────

# PRIMARY: xAI (Grok)
XAI_API_KEY=your_xai_api_key_here
XAI_MODEL=grok-beta
XAI_BASE_URL=https://api.x.ai/v1

# ALTERNATIVE: Kie.ai
KIE_API_KEY=your_kie_api_key_here
KIE_MODEL=opus-4.6
KIE_BASE_URL=https://api.kie.ai/v1

# FALLBACK: Anthropic
# Used if neither xAI nor Kie keys are set.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LOCAL: LiteRT-LM (On-device)
# Set path to a .litertlm model (e.g. Gemma 2B) to run entirely offline.
# Leave EMPTY to use cloud brains.
LITERT_MODEL_PATH=
LITERT_MAX_TOKENS=4096

# CLOUD ALTERNATIVES: OpenAI / Groq / Google
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GOOGLE_API_KEY=your_google_api_key_here


# ── Market Data Providers (Free Tier) ────────────────────────────────────────

# Binance (Public API — no key needed for crypto data)
# yfinance (Public API — no key needed for stocks/forex/commodities)

# CoinGecko (Free key — 30/min limit)
COINGECKO_API_KEY=

# CoinMarketCap (Free key — 30/min limit)
COINMARKETCAP_API_KEY=

# Alpha Vantage (Free key — 25/day limit)
ALPHAVANTAGE_API_KEY=

# Twelve Data (Free key — 8/min limit)
TWELVEDATA_API_KEY=

# Polygon.io (Free key — 5/min limit)
POLYGON_API_KEY=

# FRED (Macro data: Fed rates, CPI, GDP — Free key)
FRED_API_KEY=

# NewsAPI (News headlines — Free key)
NEWSAPI_KEY=

# LunarCrush (Social sentiment — Free key)
LUNARCRUSH_API_KEY=

# Reddit API (PRAW — Free key)
REDDIT_CLIENT_ID=
REDDIT_SECRET=
REDDIT_USER_AGENT=hedge-fund-bot/1.0


# ── Execution Brokers ─────────────────────────────────────────────────────────

# GLOBAL OVERRIDE: If true, NO real orders will ever be sent (Safe mode)
DRY_RUN_ALL=true

# 1. cTrader (Forex / CFD via IC Markets, Pepperstone, etc.)
# Run scripts/get_token.py to generate these
CTRADER_ENV=demo
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCESS_TOKEN=
CTRADER_REFRESH_TOKEN=
CTRADER_ACCOUNT_ID=

# 2. Binance (Crypto Spot)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# 3. CCXT (Universal: Kraken, Bybit, OKX, KuCoin, etc.)
# Replace KRAKEN with your exchange name (e.g. BYBIT_API_KEY)
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
KRAKEN_SANDBOX=true

# 4. Alpaca (Stocks, ETFs, Crypto)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true

# 5. OANDA (Forex)
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_PRACTICE=true


# ── Risk Management ──────────────────────────────────────────────────────────

# Core settings
RISK_PER_TRADE=0.01          # Risk 1% of equity per trade
MAX_POSITIONS=5              # Hard cap on total open trades
MIN_SIGNAL_STRENGTH=0.55     # Combined agent confidence threshold (0.0-1.0)
MIN_RISK_REWARD=1.5          # Minimum target RR ratio (e.g. 1:1.5)

# Signal Weighting (Sum must be 1.0)
WEIGHT_TECHNICAL=0.50
WEIGHT_SENTIMENT=0.25
WEIGHT_MACRO=0.25

# Kelly Criterion sizing (Advanced)
USE_KELLY=true               # Use TradeJournal stats for sizing if available

# Volatility protection
# Reduce position size by 50% if VIX is above this level
VIX_THRESHOLD=25.0


# ── Monitoring & Automation ───────────────────────────────────────────────────

# InfluxDB (For Grafana Dashboards)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=
INFLUXDB_ORG=hedge-fund
INFLUXDB_BUCKET=trading

# n8n Webhook (Send every signal/order to your automation flows)
N8N_WEBHOOK_URL=

# Telegram Bot (Real-time trade alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Logging
LOG_LEVEL=INFO


# ── Symbol Overrides ───────────────────────────────────────────────────────────

# Comma-separated lists to override default MarketConfigs
# TRADE_SYMBOLS_CRYPTO=BTC/USDT,ETH/USDT,SOL/USDT
# TRADE_SYMBOLS_FOREX=EURUSD,GBPUSD,USDJPY
# TRADE_SYMBOLS_STOCKS=NVDA,AAPL,TSLA
