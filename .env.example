# ──────────────────────────────────────────────────────────────────────────────
# AI HEDGE FUND — COMPLETE CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────

# ── AI Brain (LLM Engine) ───────────────────────────────────────────────────

# PRIMARY: xAI (Grok)
XAI_API_KEY=your_xai_api_key_here
XAI_MODEL=grok-beta
XAI_BASE_URL=https://api.x.ai/v1

# ALTERNATIVE: Kie.ai — https://docs.kie.ai/  |  Claude: https://docs.kie.ai/market/claude/claude-sonnet-4-6
KIE_API_KEY=your_kie_api_key_here
KIE_MODEL=claude-sonnet-4-6
# Direct Claude endpoint (Anthropic Messages API shape — NOT the async /v1 task API)
KIE_BASE_URL=https://api.kie.ai/claude
# Bypass broken LiteLLM proxy: route chat tasks direct to Kie (recommended on VPS)
# DEEP_ANALYSIS_LLM_PROVIDER=kie
# GENERAL_LLM_PROVIDER=kie
# PERSONA_LLM_PROVIDER=kie
# LiteLLM proxy alias for Kie Sonnet (maps to claude-sonnet-4-6 in litellm-config.yaml)
PERSONA_LLM_MODEL=claude-sonnet
PERSONA_LLM_PROVIDER=litellm
PERSONA_LLM_BASE_URL=http://litellm:4000/v1
LITELLM_API_KEY=

# FALLBACK: Anthropic
# Used if neither xAI nor Kie keys are set.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LOCAL: LiteRT-LM (On-device)
# Set path to a .litertlm model (e.g. Gemma 2B) to run entirely offline.
# Leave EMPTY to use cloud brains.
LITERT_MODEL_PATH=
LITERT_MAX_TOKENS=4096

# CLOUD ALTERNATIVES: OpenAI / Groq / Google
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GOOGLE_API_KEY=your_google_api_key_here


# ── Market Data Providers (Free Tier) ────────────────────────────────────────

# Binance (Public API — no key needed for crypto data)
# yfinance (Public API — no key needed for stocks/forex/commodities)

# CoinGecko (Free key — 30/min limit)
COINGECKO_API_KEY=

# CoinMarketCap (Free key — 30/min limit)
COINMARKETCAP_API_KEY=

# Alpha Vantage (Free key — 25/day limit)
ALPHAVANTAGE_API_KEY=

# Twelve Data (Free key — 8/min limit)
TWELVEDATA_API_KEY=

# Polygon.io (Free key — 5/min limit)
POLYGON_API_KEY=

# FRED (Macro data: Fed rates, CPI, GDP — Free key)
FRED_API_KEY=

# NewsAPI (News headlines — Free key)
NEWSAPI_KEY=

# CryptoCompare (Crypto news — Free key)
CRYPTOCOMPARE_API_KEY=

# ── Native Loops ─────────────────────────────────────────────────────────────
MACRO_LOOP_ENABLED=true
MACRO_LOOP_INTERVAL_MIN=60
GRAFANA_URL=http://72.60.18.113:8081/grafana

# OPENROUTER (Embeddings + optional chat fallback)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OpenRouter embedding model (1536d for Qdrant crypto-news)
EMBED_MODEL=openai/text-embedding-3-small
EMBED_DIMENSIONS=1536

# Native loops — market alert Telegram digest
MARKET_ALERTS_ENABLED=true
MARKET_ALERTS_INTERVAL_MINUTES=120
# Opinion layer query window — should exceed interval (default: interval + 30)
MARKET_ALERTS_LOOKBACK_MINUTES=150


# LunarCrush (Social sentiment — Free key)
LUNARCRUSH_API_KEY=

# Reddit API (PRAW — Free key)
REDDIT_CLIENT_ID=
REDDIT_SECRET=
REDDIT_USER_AGENT=hedge-fund-bot/1.0


# ── Execution Brokers ─────────────────────────────────────────────────────────

# GLOBAL OVERRIDE: If true, NO real orders will ever be sent (Safe mode)
DRY_RUN_ALL=true

# 1. cTrader (Forex / CFD via IC Markets, Pepperstone, etc.)
# Run scripts/get_token.py to generate these
CTRADER_ENV=demo
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCESS_TOKEN=
CTRADER_REFRESH_TOKEN=
CTRADER_ACCOUNT_ID=

# 2. Binance (Crypto Spot)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# 3. CCXT (Universal: Kraken, Bybit, OKX, KuCoin, etc.)
# Replace KRAKEN with your exchange name (e.g. BYBIT_API_KEY)
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
KRAKEN_SANDBOX=true

# 4. Alpaca (Stocks, ETFs, Crypto)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true

# 5. OANDA (Forex)
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_PRACTICE=true


# ── Risk Management ──────────────────────────────────────────────────────────

# Core settings
RISK_PER_TRADE=0.01          # Risk 1% of equity per trade
MAX_POSITIONS=5              # Hard cap on total open trades
MIN_SIGNAL_STRENGTH=0.55     # Combined agent confidence threshold (0.0-1.0)
MIN_RISK_REWARD=1.5          # Minimum target RR ratio (e.g. 1:1.5)

# Signal Weighting (Sum must be 1.0)
WEIGHT_TECHNICAL=0.50
WEIGHT_SENTIMENT=0.25
WEIGHT_MACRO=0.25

# Kelly Criterion sizing (Advanced)
USE_KELLY=true               # Use TradeJournal stats for sizing if available

# Volatility protection
# Reduce position size by 50% if VIX is above this level
VIX_THRESHOLD=25.0

# Safety overrides for testing (set to true to disable drawdown and other risk limits)
DISABLE_RISK_GUARD=false


# ── API access control (optional) ─────────────────────────────────────────────
# When set, POST/PUT/DELETE on /trading/* and all /api-keys /storage routes require
# Authorization: Bearer <token> or X-API-Key: <token>. GET /trading/* stays open.
ADMIN_API_KEY=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081


# ── Monitoring & Automation ───────────────────────────────────────────────────

# InfluxDB (For Grafana Dashboards)
INFLUXDB_URL=http://vps-influxdb:8086
INFLUXDB_TOKEN=
INFLUXDB_ORG=hedge-fund
INFLUXDB_BUCKET=trading-system
INFLUXDB_ADMIN_PASSWORD=change-me-strong-password
GRAFANA_PASSWORD=admin
GRAFANA_ADMIN_USER=admin

# n8n Webhook (Send every signal/order to your automation flows)
N8N_WEBHOOK_URL=

# Telegram Bot (Real-time trade alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Sentry safety watchdog (halt-first circuit breaker)
# Shared token for sentry_watchdog container + cron script POST /sentry/emergency-halt
SENTRY_WATCHDOG_TOKEN=
SENTRY_POLL_INTERVAL_SEC=10
SENTRY_FAIL_THRESHOLD=3
SENTRY_EMERGENCY_COOLDOWN_SEC=300
# Auto-resume trading after backend recovers (Telegram alert on resume)
SENTRY_AUTO_RESUME_ENABLED=true
SENTRY_RESUME_AFTER_SEC=120
SENTRY_RESUME_HEALTH_CHECKS=6
SENTRY_RESUME_REQUIRE_RECONCILE=true
# State file directory (app-data volume in Docker)
SENTRY_STATE_DIR=/app/data/sentry

# Logging
LOG_LEVEL=INFO


# ── Symbol Overrides ───────────────────────────────────────────────────────────

# Comma-separated lists to override default MarketConfigs
# TRADE_SYMBOLS_CRYPTO=BTC/USDT,ETH/USDT,SOL/USDT
# TRADE_SYMBOLS_FOREX=EURUSD,GBPUSD,USDJPY
# TRADE_SYMBOLS_STOCKS=NVDA,AAPL,TSLA

# ── Live trading symbol list (drives trading_loop) ─────────────────────────────
# MiCA/EEA: USDT is restricted for EU users — trade USDC-margined perpetuals so
# the account's USDC balance is usable margin. DOT has no USDC perp (dropped).
# This is also defaulted in docker-compose; set here to override.
TRADING_SYMBOLS=BTCUSDC,ETHUSDC,SOLUSDC,BNBUSDC,XRPUSDC,ADAUSDC,AVAXUSDC,LINKUSDC,UNIUSDC

# ── Symbol-Quality Gate (liquidity filter + blacklist) ─────────────────────────
# Reject any symbol whose Binance Futures 24h quote volume (USDT) is below this
# floor. Low-liquidity / new-listing meme symbols produced the entire realized
# loss tail (~-$300 over 81 days) via wide spreads, slippage and forced
# liquidations. Set 0 to disable the volume gate.
# NOTE: USDC perp books are far thinner than their USDT twins (UNIUSDC ~$3.8M,
# LINKUSDC ~$8.8M, AVAXUSDC ~$10M, ADAUSDC ~$16M vs $50M+ on USDT). A 50M floor
# silently drops 4 of the 9 USDC majors. 3M keeps all 9 blue-chip USDC perps
# while still excluding illiquid meme/new-listing pairs (the real loss-tail).
MIN_24H_QUOTE_VOLUME_USDT=3000000
# Hard blacklist — always skipped regardless of volume (comma-separated).
# Pre-seeded with the worst confirmed losers from live trade history.
SYMBOL_BLACKLIST=SIRENUSDT,AIGENSYNUSDT,INUSDT,BUSDT,BRUSDT,SPKUSDT,MAGMAUSDT,VELVETUSDT,HOMEUSDT,BTWUSDT,LABUSDT

# ── Min-Edge Gate (fee-churn killer) ───────────────────────────────────────────
# 81-day live history: 52% of trades were scratches (|PnL| <= $0.20) and total
# commission drag was -$193.54 on a +$64 net. A trade is only taken if its gross
# expected move to TP clears MIN_EDGE_FEE_MULT x the round-trip cost
# (2*(taker_fee + slippage) of notional). At the defaults below the TP must clear
# a ~0.30% move — well under normal ATR-driven TPs, but it kills tight scratch
# entries that can never out-earn their own fees. Set MIN_EDGE_FEE_MULT=0 to disable.
TAKER_FEE_RATE=0.0004
SLIPPAGE_RATE=0.0002
MIN_EDGE_FEE_MULT=2.5

# ── Trailing stop (ratchet-only, ATR-based) ──
# Fixes trades that run into profit then round-trip all the way back to the
# original SL (the "oscillating between SL and TP" problem). Once a position
# has moved TRAIL_ACTIVATION_ATR x ATR into profit, the stop follows the
# high-water mark by TRAIL_ATR_MULT x ATR and ONLY ever tightens (never
# loosens). The trailed level is written into the trade's stop_loss, so the
# existing SL/TP close path enforces it every 5-min cycle — no extra exchange
# order to desync. Set TRAILING_STOP_ENABLED=false to disable.
TRAILING_STOP_ENABLED=true
TRAIL_ACTIVATION_ATR=1.0
# TRAIL_ATR_MULT must be < TRAIL_ACTIVATION_ATR. At 0.8 (vs activation 1.0) the
# trail locks ~+0.2 ATR profit the moment it arms and banks ~+1.2R on a 2-ATR
# reversal, so realized winners >= losers. The old 1.5 locked a LOSS at
# activation and capped every winner below the 2.5R TP -> refunded margin bled
# out (leak #4).
TRAIL_ATR_MULT=0.8

# ── Maker (post-only) entries — fee-churn fix ──
# Historical fills were 100% TAKER (0.05%), the single largest account drain
# (~38%/mo in commission). When enabled, ENTRIES are placed as post-only (GTX)
# LIMIT orders at the near touch (maker, 0.02% or rebate). If unfilled within
# MAKER_WAIT_SEC, the order is cancelled and falls back to a MARKET order, so
# behavior degrades safely to today's taker path. Closes/SL/TP stay MARKET.
# OFF by default — set true after deploying to opt in.
MAKER_ENTRY_ENABLED=false
MAKER_WAIT_SEC=30

# ── SL/TP geometry (ATR multiples, env-tunable) ──
# Initial stop = entry -/+ SL_ATR_MULT x ATR; take-profit = entry +/- TP_ATR_MULT
# x ATR. TP_ATR_MULT is the home-run cap; the trailing stop banks the realistic
# winners before price gets there. Keep TP/SL ratio >= the min-edge multiple.
SL_ATR_MULT=1.0
TP_ATR_MULT=2.5
