# Override for LOCAL development (no nginx, direct ports)
# Use: docker compose -f docker-compose.yml -f docker-compose.override.yml up -d

services:
  backend:
    ports:
      - "8000:8000"  # Expose backend directly on host
    volumes:
      - ./backend:/app/backend  # Live reload (dev mode)
    command: ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]

  nginx:
    deploy:
      replicas: 0  # Disable nginx in local dev
